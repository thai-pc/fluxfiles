# App
FLUXFILES_SECRET=change-me-to-random-32-char-string
FLUXFILES_ALLOWED_ORIGINS=http://localhost:3000

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=

# Cloudflare R2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_BUCKET=

# Locale (optional, default: en)
# Supported: en, vi, zh, ja, ko, fr, de, es, ar, pt, it, ru, th, hi, tr, nl
# Leave empty for English. Users can override via ?lang= or ?locale= URL param.
FLUXFILES_LOCALE=

# Rate limit (optional, for tests use higher values)
# FLUXFILES_RATE_LIMIT_READ=60
# FLUXFILES_RATE_LIMIT_WRITE=100

# AI Auto-Tag (optional)
# Provider: 'claude' or 'openai' (leave empty to disable)
FLUXFILES_AI_PROVIDER=
FLUXFILES_AI_API_KEY=
FLUXFILES_AI_MODEL=
# Auto-tag images on upload (true/false)
FLUXFILES_AI_AUTO_TAG=false
