{
  "name": "@fluxfiles/vue",
  "version": "1.22.0",
  "description": "Vue 3 components and composables for FluxFiles file manager, with Nuxt 3 auto-import support",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./nuxt": {
      "import": "./dist/nuxt.mjs",
      "require": "./dist/nuxt.js",
      "types": "./dist/nuxt.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/nuxt.ts --format cjs,esm --dts --clean --external vue",
    "dev": "tsup src/index.ts src/nuxt.ts --format cjs,esm --dts --watch --external vue",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "vue": "^3.5.0",
    "vue-tsc": "^3.2.5",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "author": "thai-pc",
  "homepage": "https://github.com/thai-pc/fluxfiles#vue--nuxt",
  "repository": {
    "type": "git",
    "url": "https://github.com/thai-pc/fluxfiles.git",
    "directory": "adapters/vue"
  },
  "bugs": {
    "url": "https://github.com/thai-pc/fluxfiles/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "fluxfiles",
    "file-manager",
    "vue",
    "vue3",
    "nuxt",
    "nuxt3",
    "s3",
    "r2",
    "upload"
  ]
}
